# Shared
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
CENTER_NAME=Nova Education Center

# Database
POSTGRES_DB=kurs_boshqaruv
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<set-local-postgres-password>
DATABASE_URL=<set-local-postgres-url>

# API
API_PORT=4000
JWT_ACCESS_SECRET=<set-local-jwt-access-secret>
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=<set-local-jwt-refresh-secret>
JWT_REFRESH_TTL=7d
DEMO_USER_PASSWORD=<set-local-demo-password>

# Telegram
TELEGRAM_BOT_USERNAME=<set-telegram-bot-username>
TELEGRAM_BOT_TOKEN=<set-local-telegram-bot-token>

# Frontend
VITE_API_BASE_URL=http://localhost:4000/api
VITE_APP_NAME=Kurs Boshqaruv
VITE_USE_MOCK_API=true
VITE_DEMO_PASSWORD=<set-local-demo-password>
